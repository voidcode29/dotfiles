{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny"
    },
    "bash": {
      "rm *credentials*": "deny",
      "rm *.env*": "deny"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "provider": {
    "ALBERT": {
      "models": {
        "Qwen/Qwen3-Coder-30B-A3B-Instruct": {
          "name": "Qwen/Qwen3-Coder-30B-A3B-Instruct"
        },
        "openai/gpt-oss-120b": {
          "name": "openai/gpt-oss-120b"
        }
      },
      "options": {
        "baseURL": "https://albert.api.etalab.gouv.fr/v1"
      }
    },
    "ollama": {
      "id": "ollama",
      "api": "openai",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3.5:9b": {
          "id": "qwen3.5:9b",
          "name": "Qwen 3.5 9B",
          "tool_call": false,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "lsp": true,
  "plugin": [
    "oh-my-opencode-slim"
  ]
}
